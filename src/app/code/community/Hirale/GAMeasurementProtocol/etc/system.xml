<?xml version="1.0"?>
<config>
    <sections>
        <google>
            <groups>
                <measurement translate="label">
                    <label>Measurement Protocol</label>
                    <sort_order>10</sort_order>
                    <show_in_default>1 </show_in_default>
                    <show_in_website>1 </show_in_website>
                    <show_in_store>1</show_in_store>
                    <fields>
                        <enabled translate="label comment">
                            <label>Enable</label>
                            <frontend_type>select</frontend_type>
                            <source_model>adminhtml/system_config_source_yesno</source_model>
                            <sort_order>10</sort_order>
                            <show_in_default>1 </show_in_default>
                            <show_in_website>1 </show_in_website>
                            <show_in_store>1</show_in_store>
                        </enabled>
                        <measurement_id translate="label">
                            <label>Measurement ID</label>
                            <frontend_type>text</frontend_type>
                            <sort_order>20</sort_order>
                            <show_in_default>1 </show_in_default>
                            <show_in_website>1 </show_in_website>
                            <show_in_store>1</show_in_store>
                            <depends>
                                <enabled>1</enabled>
                            </depends>
                        </measurement_id>
                        <api_secret translate="label">
                            <label>API Secret</label>
                            <frontend_type>text</frontend_type>
                            <sort_order>30</sort_order>
                            <show_in_default>1 </show_in_default>
                            <show_in_website>1 </show_in_website>
                            <show_in_store>1</show_in_store>
                            <depends>
                                <enabled>1</enabled>
                            </depends>
                        </api_secret>
                        <debug_mode translate="label">
                            <label>Debug Mode</label>
                            <frontend_type>select</frontend_type>
                            <source_model>adminhtml/system_config_source_yesno</source_model>
                            <sort_order>40</sort_order>
                            <show_in_default>1 </show_in_default>
                            <show_in_website>1 </show_in_website>
                            <show_in_store>1</show_in_store>
                            <depends>
                                <enabled>1</enabled>
                            </depends>
                            <comment><![CDATA[When enabled, debug_mode=true is sent only to IPs listed in System > Developer > Developer Client Restrictions (dev/restrict/allow_ips). Important: this feature fails closed. If that list is empty or does not match the visitor IP exactly, no visitor receives the debug flag and no debug requests are logged. See also: https://support.google.com/analytics/answer/7201382]]></comment>
                        </debug_mode>
                        <log_file translate="label comment">
                            <label>Log File</label>
                            <frontend_type>text</frontend_type>
                            <sort_order>50</sort_order>
                            <show_in_default>1</show_in_default>
                            <show_in_website>1</show_in_website>
                            <show_in_store>1</show_in_store>
                            <depends>
                                <debug_mode>1</debug_mode>
                            </depends>
                            <comment>Log file name inside var/log/ (e.g. ga_measurement.log).</comment>
                        </log_file>
                    </fields>
                </measurement>
            </groups>
        </google>
    </sections>
</config>
